{
  "name": "reprompter",
  "version": "9.0.0",
  "private": true,
  "description": "Prompt engineering skill for Claude Code, OpenClaw, and Codex",
  "scripts": {
    "validate:templates": "bash scripts/validate-templates.sh",
    "test:intent-router": "node --test scripts/intent-router.test.js",
    "test:capability-policy": "node --test scripts/capability-policy.test.js",
    "test:context-builder": "node --test scripts/context-builder.test.js",
    "test:artifact-evaluator": "node --test scripts/artifact-evaluator.test.js",
    "test:pattern-selector": "node --test scripts/pattern-selector.test.js",
    "test:runtime-adapter": "node --test scripts/runtime-adapter.test.js",
    "test:repromptverse-runtime": "node --test scripts/repromptverse-runtime.test.js",
    "test:telemetry-schema": "node --test scripts/telemetry-schema.test.js",
    "test:telemetry-store": "node --test scripts/telemetry-store.test.js",
    "test:observability-report": "node --test scripts/run-observability-report.test.js",
    "test:recipe-fingerprint": "node --test scripts/recipe-fingerprint.test.js",
    "test:outcome-collector": "node --test scripts/outcome-collector.test.js",
    "test:strategy-learner": "node --test scripts/strategy-learner.test.js",
    "benchmark:swarms": "node scripts/run-swarm-benchmark.js",
    "benchmark:provider": "node scripts/run-provider-benchmark.js",
    "benchmark:realworld": "node scripts/run-realworld-benchmark.js",
    "benchmark:flywheel": "node scripts/run-flywheel-benchmark.js",
    "telemetry:report": "node scripts/run-observability-report.js",
    "flywheel:report": "node scripts/strategy-learner.js",
    "check": "npm run validate:templates && npm run test:intent-router && npm run test:capability-policy && npm run test:context-builder && npm run test:artifact-evaluator && npm run test:pattern-selector && npm run test:runtime-adapter && npm run test:repromptverse-runtime && npm run test:telemetry-schema && npm run test:telemetry-store && npm run test:observability-report && npm run test:recipe-fingerprint && npm run test:outcome-collector && npm run test:strategy-learner && npm run benchmark:swarms && npm run benchmark:provider && npm run benchmark:realworld && npm run benchmark:flywheel"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AytuncYildizli/reprompter.git"
  }
